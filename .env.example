VITE_APP_NAME=Liquid Glass Calendar
VITE_SHARED_CALENDAR_NAME=나의 캘린더
VITE_SHARED_CALENDAR_SLUG=personal-calendar

# local | supabase
VITE_SYNC_PROVIDER=local

# Only local-browser auth is implemented in this repo today.
VITE_AUTH_PROVIDER=local

# Fill these only if you switch to shared sync with Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional Google Calendar integration.
# If enabled in production, add your deployed origin to Google OAuth authorized origins.
VITE_ENABLE_GOOGLE_CALENDAR=false
VITE_GOOGLE_CLIENT_ID=
